# gh PR helpers (require: gh CLI authenticated via `gh auth login`)
if (( $+commands[gh] )); then
  # prc — pick a PR with fzf and check it out locally.
  prc() {
    if ! (( $+commands[fzf] )); then gh pr list; return; fi
    local pr
    pr=$(gh pr list --limit 50 \
            --json number,title,author,headRefName \
            --template '{{range .}}{{printf "#%v" .number}}  {{.title}}  ({{.author.login}}, {{.headRefName}}){{"\n"}}{{end}}' \
         | fzf --reverse --prompt='pr > ' \
               --preview 'gh pr view $(echo {} | awk "{print \$1}" | tr -d "#")' \
               --preview-window=right:60% \
         | awk '{print $1}' | tr -d '#')
    [[ -n "$pr" ]] && gh pr checkout "$pr"
  }
  # prv — pick a PR and open it in $PAGER (or the browser with `gh pr view --web`).
  prv() {
    if ! (( $+commands[fzf] )); then gh pr list; return; fi
    local pr
    pr=$(gh pr list --limit 50 \
            --json number,title,author \
            --template '{{range .}}{{printf "#%v" .number}}  {{.title}}  ({{.author.login}}){{"\n"}}{{end}}' \
         | fzf --reverse --prompt='pr > ' | awk '{print $1}' | tr -d '#')
    [[ -n "$pr" ]] && gh pr view "$pr"
  }
fi

