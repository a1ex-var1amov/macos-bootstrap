# fnm (Node.js version manager) — lazy-loaded.
# `fnm env` adds ~100ms to every shell start. Initialise on first invocation of
# node/npm/npx/pnpm/yarn instead. After that the real fnm wrapper takes over.
if (( $+commands[fnm] )); then
  _fnm_lazy_init() {
    unfunction node npm npx pnpm yarn 2>/dev/null
    eval "$(fnm env --use-on-cd --shell zsh)"
  }
  for _cmd in node npm npx pnpm yarn; do
    eval "${_cmd}() { _fnm_lazy_init && ${_cmd} \"\$@\" }"
  done
  unset _cmd
fi

