# atuin — supercharged shell history
# Replaces Ctrl+R with a fuzzy TUI showing timestamps, duration, exit codes.
# Works identically in every tmux pane/window and plain terminals — all share
# one SQLite database, so history is always complete regardless of where you
# typed a command. Up-arrow keeps default per-session behaviour.
# First-time setup: `atuin register` (or `atuin login` on a second machine).
if (( $+commands[atuin] )); then
  # One-time import of pre-existing zsh history. Marker file prevents re-importing.
  if [[ ! -f "${XDG_DATA_HOME:-$HOME/.local/share}/atuin/.imported" \
     && -s "$HISTFILE" ]]; then
    atuin import zsh 2>/dev/null \
      && mkdir -p "${XDG_DATA_HOME:-$HOME/.local/share}/atuin" \
      && touch "${XDG_DATA_HOME:-$HOME/.local/share}/atuin/.imported" \
      && echo "atuin: imported existing zsh history (one-time)"
  fi
  eval "$(atuin init zsh --disable-up-arrow)"
fi

