# kx — fzf chooser for kubectl contexts (preview shows the cluster's namespaces).
# Falls back to plain kubectx output if fzf is missing.
kx() {
  if ! (( $+commands[kubectl] )); then
    echo "kubectl not installed"; return 1
  fi
  if ! (( $+commands[fzf] )); then
    command kubectx; return $?
  fi
  local ctx
  ctx=$(kubectl config get-contexts -o name 2>/dev/null \
        | fzf --reverse --prompt='ctx > ' \
              --preview 'kubectl --context={} get ns 2>/dev/null | head -25' \
              --preview-window=right:50%)
  [[ -n "$ctx" ]] && kubectl config use-context "$ctx"
}

# kn — fzf chooser for current-context namespace.
kn() {
  if ! (( $+commands[kubectl] )); then
    echo "kubectl not installed"; return 1
  fi
  if ! (( $+commands[fzf] )); then
    command kubens 2>/dev/null || kubectl get ns; return $?
  fi
  local ns
  ns=$(kubectl get ns -o name 2>/dev/null \
        | sed 's|^namespace/||' \
        | fzf --reverse --prompt='ns > ' \
              --preview 'kubectl -n {} get pods 2>/dev/null | head -25' \
              --preview-window=right:60%)
  [[ -n "$ns" ]] && kubectl config set-context --current --namespace="$ns" \
                 && echo "namespace -> $ns"
}

