# Map the active theme key + dark/light mode onto bat + delta and export
# BAT_THEME / GIT_CONFIG_PARAMETERS for the current shell. Single source of
# truth — used by the startup block below AND by theme-sync, so the two can't
# drift apart again.
function _apply-bat-delta-theme() {
  local t="$1" mode="$2" bt
  case "$t" in
    catppuccin-mocha|catppuccin-macchiato) bt="Catppuccin Mocha" ;;
    catppuccin-frappe)                     bt="Catppuccin Frappe" ;;
    catppuccin-latte)                      bt="Catppuccin Latte" ;;
    dracula)                               bt="Dracula" ;;
    gruvbox-dark)                          bt="gruvbox-dark" ;;
    gruvbox-light)                         bt="gruvbox-light" ;;
    nord)                                  bt="Nord" ;;
    solarized-dark)                        bt="Solarized (dark)" ;;
    solarized-light)                       bt="Solarized (light)" ;;
    github-light)                          bt="GitHub" ;;
    # ponytail: bat ships no builtins for tokyo-night / kanagawa / everforest /
    # rose-pine / github-dark / nord-light / dracula-alucard — generic dark/
    # light fallbacks. Upgrade path: drop .tmTheme files into
    # ~/.config/bat/themes and extend this case.
    *) [[ "$mode" == dark ]] && bt="base16" || bt="GitHub" ;;
  esac
  export BAT_THEME="$bt"
  # Light themes need delta's light-mode diff colors too
  case "$bt" in
    GitHub|"Catppuccin Latte"|OneHalfLight|"Solarized (light)"|gruvbox-light)
      export GIT_CONFIG_PARAMETERS="'delta.syntax-theme=${bt}' 'delta.light=true'" ;;
    *)
      export GIT_CONFIG_PARAMETERS="'delta.syntax-theme=${bt}' 'delta.light=false'" ;;
  esac
}

if (( $+commands[bat] )); then
  # Pick bat theme matching macOS dark/light mode and active color scheme
  () {
    local _is_dark _t _mode
    _is_dark="$(defaults read -g AppleInterfaceStyle 2>/dev/null)"
    [[ "$_is_dark" == "Dark" ]] && _mode=dark || _mode=light
    if [[ -f ~/.config/terminal-theme-pair ]]; then
      local THEME_DARK THEME_LIGHT
      source ~/.config/terminal-theme-pair
      [[ "$_mode" == dark ]] && _t="$THEME_DARK" || _t="$THEME_LIGHT"
    else
      local COLOR_THEME
      source ~/.config/terminal-color-theme 2>/dev/null
      _t="$COLOR_THEME"
    fi
    _apply-bat-delta-theme "$_t" "$_mode"
  }
  alias cat="bat --paging=never"
  alias catp="bat"  # with pager
fi

