# --- Automatic Tab/Window Title ---
# Cache k8s context to avoid calling kubectl on every prompt
_CACHED_K8S_CTX=""
_CACHED_K8S_TIME=0

# Parallel implementation lives at configs/tmux/scripts/k8s-context.sh
# (used by tmux status bar). Keep the two in sync when adding patterns.
function _shorten_k8s_context() {
  local ctx="$1"

  # AWS EKS: arn:aws:eks:region:account:cluster/NAME -> NAME
  if [[ "$ctx" =~ :cluster/([^/]+)$ ]]; then
    echo "${match[1]}"
    return
  fi

  # GKE: gke_project_region_NAME -> NAME
  if [[ "$ctx" =~ ^gke_.*_([^_]+)$ ]]; then
    echo "${match[1]}"
    return
  fi

  # OpenShift API URL with dots: api.CLUSTER.domain.com:port -> CLUSTER
  if [[ "$ctx" =~ ^api\.([^.]+)\. ]]; then
    echo "${match[1]}"
    return
  fi

  # OpenShift API URL with slashes: namespace/api-CLUSTER-domain-com:port/user -> CLUSTER
  if [[ "$ctx" =~ /api-([^:/]+) ]]; then
    local extracted="${match[1]}"
    # Strip trailing domain segments (-com, -io, -org, etc.)
    extracted="${extracted%-com}"
    extracted="${extracted%-io}"
    extracted="${extracted%-org}"
    extracted="${extracted%-net}"
    echo "$extracted"
    return
  fi

  # Kubeadm: kubernetes-admin@CLUSTER -> CLUSTER
  if [[ "$ctx" =~ ^kubernetes-admin@(.+)$ ]]; then
    echo "${match[1]}"
    return
  fi

  # Docker Desktop
  [[ "$ctx" == "docker-desktop" ]] && echo "docker" && return

  # ── User-defined patterns (~/.config/k8s-context-patterns) ────────────────
  # Format: one rule per line → <substring> <display-name>
  # Lines starting with # are comments. Example:
  #   my-company-dev    dev
  #   my-company-prod   prod
  if [[ -f ~/.config/k8s-context-patterns ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
      local pat="${line%% *}"
      local rep="${line#* }"
      [[ "$ctx" == *"$pat"* ]] && echo "$rep" && return
    done < ~/.config/k8s-context-patterns
  fi

  # Default: return as-is, truncate if too long
  if (( ${#ctx} > 25 )); then
    echo "${ctx:0:22}..."
  else
    echo "$ctx"
  fi
}

function _get_k8s_context() {
  local now=$EPOCHSECONDS
  # Refresh cache every 5 seconds
  if (( now - _CACHED_K8S_TIME > 5 )); then
    if (( $+commands[kubectl] )); then
      local raw_ctx=$(kubectl config current-context 2>/dev/null)
      _CACHED_K8S_CTX=$(_shorten_k8s_context "$raw_ctx")
    fi
    _CACHED_K8S_TIME=$now
  fi
  echo "$_CACHED_K8S_CTX"
}

function _set_terminal_title() {
  local title_dir="${PWD/#$HOME/~}"
  title_dir="${title_dir:t}"  # basename only
  [[ -z "$title_dir" ]] && title_dir="~"
  
  local k8s_ctx=$(_get_k8s_context)
  local title="$title_dir"
  [[ -n "$k8s_ctx" ]] && title="$title | $k8s_ctx"
  
  # Set terminal/pane title
  if [[ -n "$TMUX" ]]; then
    local tmux_session=$(tmux display-message -p '#S' 2>/dev/null)
    # Inside tmux: set pane title (visible in pane border / status bar)
    print -Pn "\e]2;${title}\a"
    tmux rename-window "$title_dir" 2>/dev/null  # Set tmux window name to just folder
    # Pass through to outer terminal (Ghostty): always show tx-<session>
    print -Pn "\ePtmux;\e\e]0;tx-${tmux_session}\a\e\\"
  else
    # Outside tmux: set terminal title directly
    print -Pn "\e]0;${title}\a"
  fi
}

# Use zle-line-init to set title RIGHT before prompt is ready for input
# This ensures it runs AFTER everything else
function zle-line-init() {
  _set_terminal_title
}
zle -N zle-line-init

# Show running command in title while executing
function _set_title_preexec() {
  local cmd="${1[(w)1]}"
  if [[ -n "$TMUX" ]]; then
    local tmux_session=$(tmux display-message -p '#S' 2>/dev/null)
    print -Pn "\e]2;${cmd} ...\a"
    # Keep tx-<session> in Ghostty bar even while a command runs
    print -Pn "\ePtmux;\e\e]0;tx-${tmux_session}\a\e\\"
  else
    print -Pn "\e]0;${cmd} ...\a"
  fi
}
autoload -Uz add-zsh-hook
