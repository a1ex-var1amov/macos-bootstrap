# Smart tmux session management
# Creates/attaches to session named after current folder + k8s context.
# Safe to call from inside tmux — uses switch-client instead of attach.
function ts() {
  local session_name="${1:-}"

  if [[ -z "$session_name" ]]; then
    local folder="${PWD:t}"
    [[ -z "$folder" || "$folder" == "/" ]] && folder="root"

    local k8s_ctx=""
    if (( $+commands[kubectl] )); then
      k8s_ctx=$(kubectl config current-context 2>/dev/null)
      k8s_ctx=$(_shorten_k8s_context "$k8s_ctx")
    fi

    if [[ -n "$k8s_ctx" ]]; then
      session_name="${folder}_${k8s_ctx}"
    else
      session_name="$folder"
    fi
  fi

  # Sanitize name — tmux forbids dots/colons, and whitespace causes selection
  # ambiguity with `tmux attach -t name with spaces`.
  session_name="${session_name//[.:[:space:]]/-}"

  if ! tmux has-session -t="$session_name" 2>/dev/null; then
    tmux new-session -ds "$session_name" -c "$PWD"
  fi

  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach -t "$session_name"
  fi
}

# List and pick session with fzf (if available).
# Inside tmux uses switch-client; outside tmux attaches.
function tsp() {
  local picker session
  if (( $+commands[fzf] )); then
    picker="fzf --height 40% --reverse"
  else
    tmux list-sessions 2>/dev/null
    echo "Install fzf for interactive picker, or use: tmux attach -t SESSION"
    return 1
  fi

  session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | eval "$picker")
  [[ -z "$session" ]] && return 0

  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach -t "$session"
  fi
}

# tmux session with a specific KUBECONFIG — for side-by-side multi-cluster work.
# Usage: tsk <cluster-shortname>   reads ~/.kube/<cluster>.yaml
#        tsk <cluster> <session-name>
# Cluster-aware session name: <folder>_<cluster>, exported KUBECONFIG isolated
# per session. Open two such sessions in separate Ghostty splits or peek via
# `Prefix + P` to view two clusters at once.
function tsk() {
  local cluster="${1:-}"
  if [[ -z "$cluster" ]]; then
    echo "Usage: tsk <cluster-shortname> [session-name]"
    echo "  Looks for ~/.kube/<cluster>.yaml (or ~/.kube/<cluster>)"
    if [[ -d "$HOME/.kube" ]]; then
      echo "  Available kubeconfigs:"
      ls -1 "$HOME/.kube" 2>/dev/null | grep -E '\.(yaml|yml|conf)?$' | sed 's/^/    /'
    fi
    return 1
  fi

  local kubeconfig=""
  for candidate in "$HOME/.kube/${cluster}.yaml" "$HOME/.kube/${cluster}.yml" "$HOME/.kube/${cluster}" "$HOME/.kube/config-${cluster}"; do
    [[ -f "$candidate" ]] && { kubeconfig="$candidate"; break; }
  done
  if [[ -z "$kubeconfig" ]]; then
    echo "No kubeconfig found for '$cluster' (tried ~/.kube/${cluster}.{yaml,yml,} and ~/.kube/config-${cluster})"
    return 1
  fi

  local session_name="${2:-${PWD:t}_${cluster}}"
  session_name="${session_name//[.:[:space:]]/-}"

  if ! tmux has-session -t="$session_name" 2>/dev/null; then
    tmux new-session -ds "$session_name" -c "$PWD" -e "KUBECONFIG=$kubeconfig"
  fi

  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$session_name"
  else
    tmux attach -t "$session_name"
  fi
}

alias tls="tmux list-sessions"
alias tks="tmux kill-session -t"
alias tad="tmux attach -d"  # attach + detach other clients (steal session)

# tka — kill the ENTIRE tmux server (all sessions). Always confirms.
function tka() {
  local count
  count=$(tmux list-sessions 2>/dev/null | wc -l | awk '{print $1}')
  if (( count == 0 )); then
    echo "No tmux sessions running."
    return 0
  fi
  read -q "?Kill ALL $count tmux session(s)? [y/N] " || { echo; return 1; }
  echo
  tmux kill-server && echo "All sessions killed."
}

# --- Useful functions ---
# Create directory and cd into it
mkcd() { mkdir -p "$1" && cd "$1" }

# Extract various archive formats
extract() {
  if [ -f "$1" ]; then
    case "$1" in
      *.tar.bz2)   tar xjf "$1"                                 ;;
      *.tar.gz)    tar xzf "$1"                                 ;;
      *.tar.xz)    tar xJf "$1"                                 ;;
      *.tar.zst)   tar --use-compress-program=unzstd -xf "$1"   ;;
      *.tar)       tar xf  "$1"                                 ;;
      *.tbz2)      tar xjf "$1"                                 ;;
      *.tgz)       tar xzf "$1"                                 ;;
      *.bz2)       bunzip2 "$1"                                 ;;
      *.gz)        gunzip "$1"                                  ;;
      *.xz)        unxz "$1"                                    ;;
      *.zst)       unzstd "$1"                                  ;;
      *.zip)       unzip "$1"                                   ;;
      *.rar)       unrar e "$1"                                 ;;
      *.Z)         uncompress "$1"                              ;;
      *.7z)        7z x "$1"                                    ;;
      *)           echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# Find files by name (case-insensitive) — uses fd when available
ff()   { (( $+commands[fd] )) && fd -t f "$1" || command find . -type f -iname "*$1*" }

# Find directories by name (case-insensitive) — uses fd when available
fdir() { (( $+commands[fd] )) && fd -t d "$1" || command find . -type d -iname "*$1*" }

# Quick search in history
h() { history | grep "$1" }

# Show top 10 commands from history (fc -l is the zsh-native way)
topcmd() { fc -l 1 | awk '{print $2}' | sort | uniq -c | sort -rn | head -10 }

