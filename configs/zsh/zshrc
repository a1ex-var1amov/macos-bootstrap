# yazi — TUI file manager. `yy` opens it and cd's the shell to its exit dir
# (lets you "navigate visually, return to shell where you ended up").
if (( $+commands[yazi] )); then
  alias y="yazi"
  yy() {
    local tmp; tmp=$(mktemp -t "yazi-cwd.XXXXXX")
    yazi "$@" --cwd-file="$tmp"
    if cwd=$(command cat -- "$tmp" 2>/dev/null) && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
      builtin cd -- "$cwd"
    fi
    \rm -f -- "$tmp"
  }
fi

