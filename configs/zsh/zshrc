# fzf (fuzzy finder): key bindings, completion, and global look-and-feel.
# FZF_DEFAULT_OPTS applies to every fzf invocation (Ctrl+R, Ctrl+T, kx/kn/prc,
# fzf-tab, tmux popups). Keep this short — flags that need a preview window
# (kx, kn, prc) override their own --preview-window per call.
export FZF_DEFAULT_OPTS=" \
  --height=40% \
  --layout=reverse \
  --border=rounded \
  --info=inline \
  --prompt=' > ' \
  --pointer='›' \
  --marker='›' \
  --bind=ctrl-/:toggle-preview,ctrl-j:down,ctrl-k:up,alt-a:select-all,alt-d:deselect-all"
# fd is faster than find and respects .gitignore. Falls back silently if absent.
