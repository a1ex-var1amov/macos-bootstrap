# --- Dark / light theme sync ---
# Switches tmux and Neovim to match macOS appearance.
# Requires a theme pair (any install.sh / theme-switch choice), which writes:
#   ~/.config/terminal-theme-pair   (THEME_DARK + THEME_LIGHT vars)
#   ~/.config/tmux/themes/          (all tmux theme files)
#   ~/.config/nvim/lua/themes/      (all nvim theme files)
#
# Usage:
#   theme-sync          auto-detect macOS dark/light and apply
#   theme-sync dark     force dark theme
#   theme-sync light    force light theme
function theme-sync() {
  if [[ ! -f ~/.config/terminal-theme-pair ]]; then
    echo "No theme pair configured. Run install.sh (or theme-switch) and pick one."
    return 1
  fi
  source ~/.config/terminal-theme-pair

  local mode="${1:-auto}"
  if [[ "$mode" == "auto" ]]; then
    mode=$(defaults read -g AppleInterfaceStyle 2>/dev/null || echo "light")
    mode="${mode:l}"  # lowercase
  fi

  local theme
  [[ "$mode" == "dark" ]] && theme="$THEME_DARK" || theme="$THEME_LIGHT"

  # Tmux
  local tmux_theme_src="$HOME/.config/tmux/themes/${theme}.conf"
  if [[ -f "$tmux_theme_src" ]]; then
    cp "$tmux_theme_src" ~/.config/tmux-theme.conf
    tmux source-file ~/.tmux.conf 2>/dev/null && \
      echo "Tmux → $theme"
  else
    echo "Tmux theme file not found: $tmux_theme_src (re-run install.sh)"
  fi

  # Neovim
  local nvim_theme_src="$HOME/.config/nvim/lua/themes/${theme}.lua"
  if [[ -f "$nvim_theme_src" ]]; then
    cp "$nvim_theme_src" ~/.config/nvim/lua/active_theme.lua
    echo "Neovim → $theme (takes effect in new nvim instances)"
  else
    echo "Nvim theme file not found: $nvim_theme_src (re-run install.sh)"
  fi

  # bat / delta — update in the running shell immediately (shared mapping,
  # defined next to the bat startup block above)
  _apply-bat-delta-theme "$theme" "$mode"
  echo "bat/delta → $BAT_THEME"
}
