# Global gitignore — applies to every repo on this machine
# Installed to ~/.gitignore_global by install.sh

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Environment / secrets
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx

# Editor swap / session files
*.swp
*.swo
*~
.vim/
.nvimrc.lua
.idea/
*.iml
# .vscode/ — only ignore per-user files, NOT the whole folder. Many projects
# commit shared launch.json / tasks.json / extensions.json for onboarding.
.vscode/settings.json
.vscode/*.log
.history/
*.code-workspace

# Compiled / build artifacts
*.o
*.pyc
*.class
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Dependency directories (belt-and-suspenders — project .gitignore handles these too)
node_modules/

# direnv — per-directory env caches (per-machine, never commit)
.direnv/

# Terraform — state and provider caches are machine-local
.terraform/
*.tfstate
*.tfstate.*
*.tfvars.local
crash.log
crash.*.log

# Python coverage / build outputs
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/

# JS test/build artifacts
.nyc_output/
coverage/

# Misc tool caches
.cache/
.parcel-cache/
.next/

# Cursor / Claude scratchpads (machine-local)
.cursor/
.claude/
