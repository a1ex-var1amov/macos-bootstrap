# SSH client config — sensible macOS defaults.
# Installed to ~/.ssh/config by install.sh (only if you don't already have one).
#
# Layout:
#   - Host-specific overrides go in ~/.ssh/config.d/<name>.conf  (loaded first)
#   - Local-only / secret entries go in ~/.ssh/config.local      (also loaded)
#   - Defaults below apply to every host that wasn't matched above.
#
# After editing: no reload needed; each new `ssh` invocation re-reads the file.

# Load any per-host snippets you drop in ~/.ssh/config.d/  (work, personal, …).
Include ~/.ssh/config.d/*.conf
Include ~/.ssh/config.local

Host *
    # Use macOS Keychain to remember key passphrases across reboots — works
    # transparently with ssh-add (--apple-use-keychain). Without UseKeychain you
    # re-type the passphrase every login.
    UseKeychain          yes

    # Add the key to ssh-agent on first use so subsequent commands (git push,
    # rsync, scp...) don't re-prompt within the same session.
    AddKeysToAgent       yes

    # Only offer the explicitly configured IdentityFile(s) — prevents the
    # client from cycling through every key in ~/.ssh/ and tripping GitHub /
    # cloud provider rate limits ("Too many authentication failures").
    IdentitiesOnly       yes

    # Default identity. Generated by install.sh on first run. Override per-host
    # in ~/.ssh/config.d/ if you keep multiple keys (work vs personal).
    IdentityFile         ~/.ssh/id_ed25519

    # Keep connections alive across flaky Wi-Fi / sleep cycles.
    ServerAliveInterval  60
    ServerAliveCountMax  3
    TCPKeepAlive         yes

    # Reuse a single TCP connection for multiple ssh sessions to the same host.
    # Subsequent ssh / scp / rsync commands skip the handshake — 10x faster.
    ControlMaster        auto
    ControlPath          ~/.ssh/sockets/%r@%h-%p
    ControlPersist       10m

    # Don't pollute remote ~/.bash_history with locale exports from your laptop.
    SendEnv              LANG LC_*

    # Security: prefer modern algorithms, drop legacy ones automatically.
    HashKnownHosts       yes

    # Visual host-key fingerprint on first connection — easier to spot a MitM.
    VisualHostKey        yes
