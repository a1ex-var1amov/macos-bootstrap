#!/usr/bin/env bash
# theme-switch — fast standalone theme changer for the macos-bootstrap repo.
#
# Only touches theme-related config; skips the heavy install.sh path
# (no brew installs, no extension installs, no ssh/git prompts). Typically
# runs in well under a second.
#
# Usage:
#   theme-switch                     # interactive menu (with current pair shown)
#   theme-switch <n|key>             # non-interactive; n = 1-15 or a theme key
#   theme-switch --list              # print all pairs and exit
#   theme-switch --current           # print the currently active pair and exit
#   theme-switch --slack             # print/copy Slack theme strings for the current pair and exit
#   theme-switch -h | --help
#
# Examples:
#   theme-switch 11                  # → Gruvbox pair
#   theme-switch gruvbox             # → same thing, by name
#   theme-switch catppuccin-frappe   # legacy single-theme keys still work
#
# What actually changes:
#   ~/.config/terminal-color-theme         (COLOR_THEME=<dark>)
#   ~/.config/terminal-theme-pair          (THEME_DARK=<> THEME_LIGHT=<>)
#   ~/.config/ghostty/config               (theme = dark:X,light:Y)
#   ~/Library/Application Support/…/config (Ghostty app-bundle config, mirrored if stale)
#   ~/Library/Application Support/Cursor/User/settings.json    (re-rendered)
#   ~/Library/Application Support/Code/User/settings.json      (re-rendered)
#   ~/.config/tmux-theme.conf              (active tmux palette)
#   ~/.config/nvim/lua/active_theme.lua    (active nvim palette)
#   Slack has no config file — its sidebar theme string is printed + copied
#   to the clipboard (if Slack.app is installed) for a manual paste.
#
# After running: Ghostty is nudged to reload automatically (SIGUSR2, falls
# back to the Cmd+Shift+, keybind on very old Ghostty versions); tmux/nvim
# live-reload on their own; Cursor / VS Code need a Reload Window
# (Cmd+Shift+P → "Developer: Reload Window") to pick up new colors.

set -euo pipefail

# ── Locate the repo relative to this script ─────────────────────────────────
# Support two install layouts:
#   1) Symlink at ~/.local/bin/theme-switch → repo/bin/theme-switch
#      (resolve the symlink; repo = parent of bin/)
#   2) Executed directly from repo/bin/theme-switch
BIN_PATH="${BASH_SOURCE[0]}"
if [[ -L "$BIN_PATH" ]]; then
    if command -v readlink >/dev/null 2>&1; then
        # readlink -f is GNU-only; do a manual resolve loop for macOS
        while [[ -L "$BIN_PATH" ]]; do
            RESOLVED="$(readlink "$BIN_PATH")"
            case "$RESOLVED" in
                /*) BIN_PATH="$RESOLVED" ;;
                *)  BIN_PATH="$(cd "$(dirname "$BIN_PATH")" && pwd)/$RESOLVED" ;;
            esac
        done
    fi
fi
REPO="$(cd "$(dirname "$BIN_PATH")/.." && pwd)"
export THEME_LIB_REPO="$REPO"

# shellcheck source=../lib/theme-lib.sh
source "$REPO/lib/theme-lib.sh"

# ── Terminal colors (mirror install.sh's palette for a consistent feel) ─────
if [[ -t 1 ]]; then
    C_G=$'\033[32m'  # green
    C_Y=$'\033[33m'  # yellow
    C_B=$'\033[34m'  # blue
    C_D=$'\033[2m'   # dim
    C_R=$'\033[0m'   # reset
else
    C_G="" C_Y="" C_B="" C_D="" C_R=""
fi

status()   { printf "%s%s%s\n" "$C_B" "$*" "$C_R"; }
success()  { printf "%s✔%s %s\n" "$C_G" "$C_R" "$*"; }
warn()     { printf "%s⚠%s %s\n" "$C_Y" "$C_R" "$*"; }

# ── Argument parsing ────────────────────────────────────────────────────────
usage() {
    cat <<EOF
theme-switch — fast pair-based theme swap (no full install).

Usage:
  theme-switch                     Interactive menu (shows current pair)
  theme-switch <n|key>             Non-interactive. n = 1-$THEME_LIB_MAX_CHOICE or theme key.
  theme-switch --list              Print all pairs and exit
  theme-switch --current           Print the currently active pair and exit
  theme-switch --slack             Print/copy Slack theme strings for the current pair and exit
  theme-switch -h | --help         This message

Keys (all map to a menu number; you can also pass numbers directly):
$(for i in $(seq 1 "$THEME_LIB_MAX_CHOICE"); do
    printf "  %2d  %s\n" "$i" "$(theme_choice_label "$i")"
done)

Legacy single-theme keys (catppuccin-mocha, tokyo-night-day, dracula-alucard,
etc.) also work and map to their closest pair.

Requires the macos-bootstrap repo to have been installed at least once (this
script needs ~/.config/nvim/, ~/.config/ghostty/themes/, etc. — created by
install.sh).
EOF
}

print_list() {
    for i in $(seq 1 "$THEME_LIB_MAX_CHOICE"); do
        printf "  %2d  %s\n" "$i" "$(theme_choice_label "$i")"
    done
}

print_current() {
    if [[ -f ~/.config/terminal-theme-pair ]]; then
        # shellcheck disable=SC1090
        source ~/.config/terminal-theme-pair
        printf "%s ↔ %s\n" "${THEME_DARK:-<unset>}" "${THEME_LIGHT:-<unset>}"
    else
        echo "<no theme pair active — run theme-switch to pick one>"
    fi
}

print_slack() {
    if [[ ! -f ~/.config/terminal-theme-pair ]]; then
        warn "No theme pair active — run theme-switch to pick one first."
        exit 1
    fi
    # shellcheck disable=SC1090
    source ~/.config/terminal-theme-pair
    if [[ -z "${THEME_DARK:-}" || -z "${THEME_LIGHT:-}" ]]; then
        warn "No theme pair active — run theme-switch to pick one first."
        exit 1
    fi
    compute_vscode_pair_metadata "$THEME_DARK" "$THEME_LIGHT"
    status "Slack sidebar theme for: $THEME_DARK ↔ $THEME_LIGHT"
    print_slack_theme_block "$THEME_DARK" "$SLACK_THEME_DARK" "$THEME_LIGHT" "$SLACK_THEME_LIGHT" success
}

# ── Handle flags first (all short-circuit) ──────────────────────────────────
case "${1:-}" in
    -h|--help)     usage;         exit 0 ;;
    --list)        print_list;    exit 0 ;;
    --current)     print_current; exit 0 ;;
    --slack)       print_slack;   exit 0 ;;
esac

# ── Resolve the desired choice ──────────────────────────────────────────────
# Precedence: argv → interactive menu.
CHOICE=""
CURRENT_DARK=""
CURRENT_LIGHT=""
if [[ -f ~/.config/terminal-theme-pair ]]; then
    # shellcheck disable=SC1090
    source ~/.config/terminal-theme-pair
    CURRENT_DARK="${THEME_DARK:-}"
    CURRENT_LIGHT="${THEME_LIGHT:-}"
fi

if [[ -n "${1:-}" ]]; then
    CHOICE="$(theme_key_to_choice "$1")"
else
    echo ""
    if [[ -n "$CURRENT_DARK" ]]; then
        printf "%sCurrent pair:%s %s ↔ %s\n\n" \
            "$C_D" "$C_R" "$CURRENT_DARK" "$CURRENT_LIGHT"
    fi
    echo "Available theme pairs:"
    echo ""
    # 2-column layout to stay compact (8 rows for 15 items).
    HALF=$(( (THEME_LIB_MAX_CHOICE + 1) / 2 ))
    for i in $(seq 1 "$HALF"); do
        j=$(( i + HALF ))
        left="$(printf '%2d  %s' "$i" "$(theme_choice_label "$i")")"
        if (( j <= THEME_LIB_MAX_CHOICE )); then
            right="$(printf '%2d  %s' "$j" "$(theme_choice_label "$j")")"
            printf "  %-48s   %s\n" "$left" "$right"
        else
            printf "  %s\n" "$left"
        fi
    done
    echo ""
    read -rp "Pick [1-$THEME_LIB_MAX_CHOICE or theme key, empty to cancel]: " reply
    if [[ -z "$reply" ]]; then
        warn "Cancelled — no changes made."
        exit 0
    fi
    CHOICE="$(theme_key_to_choice "$reply")"
fi

# ── Resolve the pair from the choice ────────────────────────────────────────
theme_choice_to_pair "$CHOICE" >/dev/null   # side-effect: sets $THEME_DARK / $THEME_LIGHT
NEW_DARK="$THEME_DARK"
NEW_LIGHT="$THEME_LIGHT"

# Skip-work fast path: already on this pair.
if [[ "$NEW_DARK" == "$CURRENT_DARK" && "$NEW_LIGHT" == "$CURRENT_LIGHT" ]]; then
    success "Already on $NEW_DARK ↔ $NEW_LIGHT — nothing to do."
    exit 0
fi

status "Switching to $NEW_DARK ↔ $NEW_LIGHT"

# ── Prerequisite check — theme files must exist ─────────────────────────────
MISSING=()
[[ -f "$REPO/configs/ghostty/themes/$NEW_DARK"          ]] || MISSING+=("ghostty:$NEW_DARK")
[[ -f "$REPO/configs/ghostty/themes/$NEW_LIGHT"         ]] || MISSING+=("ghostty:$NEW_LIGHT")
[[ -f "$REPO/configs/tmux/themes/$NEW_DARK.conf"        ]] || MISSING+=("tmux:$NEW_DARK")
[[ -f "$REPO/configs/nvim/themes/$NEW_DARK.lua"         ]] || MISSING+=("nvim:$NEW_DARK")
if (( ${#MISSING[@]} > 0 )); then
    warn "Missing theme files: ${MISSING[*]}"
    warn "Run ./install.sh from $REPO first to deploy the theme files."
    exit 1
fi

# ── Persist the choice ──────────────────────────────────────────────────────
save_theme_choice "$NEW_DARK" "$NEW_LIGHT"

# ── Ghostty ─────────────────────────────────────────────────────────────────
mkdir -p ~/.config/ghostty/themes
# Refresh theme files defensively (cheap; means a pull-only workflow works).
for f in "$REPO"/configs/ghostty/themes/*; do
    cp "$f" ~/.config/ghostty/themes/
done
render_ghostty_config "dark:$NEW_DARK,light:$NEW_LIGHT"
ECHO_OK=success ensure_ghostty_appsupport_shim
if pgrep -x ghostty >/dev/null 2>&1; then
    reload_ghostty_if_running
    success "Ghostty  → dark:$NEW_DARK,light:$NEW_LIGHT (reloaded automatically)"
else
    success "Ghostty  → dark:$NEW_DARK,light:$NEW_LIGHT"
fi

# ── Cursor / VS Code ────────────────────────────────────────────────────────
compute_vscode_pair_metadata "$NEW_DARK" "$NEW_LIGHT"

# Rendering settings.json alone isn't enough — if the pair's theme extension
# was never installed (e.g. install.sh ran with a *different* pair chosen),
# Cursor/VS Code silently keep whatever theme was already active instead of
# erroring, which looks exactly like "the switch didn't work". Install any
# missing extension for this pair before/alongside the settings rewrite.
# --list-extensions is checked first (offline, instant) so re-switching to an
# already-seen pair stays fast; only a genuinely new pair touches the network.
CURSOR_DIR="$HOME/Library/Application Support/Cursor/User"
if [[ -d "$CURSOR_DIR" ]]; then
    if command -v cursor >/dev/null 2>&1; then
        ECHO_OK=success ensure_vscode_extensions cursor \
            catppuccin.catppuccin-vsc catppuccin.catppuccin-vsc-icons \
            "$VSCODE_DARK_EXT" "$VSCODE_LIGHT_EXT"
    fi
    render_vscode_settings \
        "$REPO/configs/cursor/settings-base.json" \
        "$CURSOR_DIR/settings.json"
    success "Cursor   → $VSCODE_DARK_THEME ↔ $VSCODE_LIGHT_THEME (reload window to apply)"
fi

VSCODE_DIR="$HOME/Library/Application Support/Code/User"
if [[ -d "$VSCODE_DIR" ]]; then
    if command -v code >/dev/null 2>&1; then
        ECHO_OK=success ensure_vscode_extensions code \
            catppuccin.catppuccin-vsc catppuccin.catppuccin-vsc-icons \
            "$VSCODE_DARK_EXT" "$VSCODE_LIGHT_EXT"
    fi
    render_vscode_settings \
        "$REPO/configs/vscode/settings-base.json" \
        "$VSCODE_DIR/settings.json"
    success "VS Code  → $VSCODE_DARK_THEME ↔ $VSCODE_LIGHT_THEME (reload window to apply)"
fi

# ── Tmux ────────────────────────────────────────────────────────────────────
mkdir -p ~/.config/tmux/themes
for f in "$REPO"/configs/tmux/themes/*.conf; do
    cp "$f" ~/.config/tmux/themes/
done
if apply_tmux_theme "$NEW_DARK"; then
    if command -v tmux >/dev/null 2>&1 && tmux info &>/dev/null; then
        success "Tmux     → $NEW_DARK (live-reloaded)"
    else
        success "Tmux     → $NEW_DARK (server not running — will pick up on next start)"
    fi
fi

# ── Neovim ──────────────────────────────────────────────────────────────────
mkdir -p ~/.config/nvim/lua/themes
for f in "$REPO"/configs/nvim/themes/*.lua; do
    [[ "$(basename "$f")" == "theme_base.lua" ]] && continue
    cp "$f" ~/.config/nvim/lua/themes/
done
if apply_nvim_theme "$NEW_DARK"; then
    success "Neovim   → $NEW_DARK (open a new nvim, or :source \$MYVIMRC in an existing one)"
fi

# ── Slack ───────────────────────────────────────────────────────────────────
# No config file/API to push this into Slack automatically — print + copy
# the string instead. compute_vscode_pair_metadata (above) already populated
# SLACK_THEME_DARK/LIGHT from this exact pair.
if app_installed "Slack"; then
    print_slack_theme_block "$NEW_DARK" "$SLACK_THEME_DARK" "$NEW_LIGHT" "$SLACK_THEME_LIGHT" success
fi

echo ""
success "Done. Reload Cursor / VS Code windows to see the new pair take effect."
